# ============================================================
# OpsPilot — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=opspilot
POSTGRES_USER=opspilot
POSTGRES_PASSWORD=opspilot_secret
DATABASE_URL=postgres://opspilot:opspilot_secret@postgres:5432/opspilot?sslmode=disable

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── NATS ────────────────────────────────────────────────────
NATS_URL=nats://nats:4222

# ── Clerk (Auth) ─────────────────────────────────────────────
# Get these from https://clerk.com → Your App → API Keys
# Required for ALL Go services (JWT validation)
CLERK_SECRET_KEY=sk_test_REPLACE_ME
# Used in frontend only:
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── API Gateway ──────────────────────────────────────────────
GATEWAY_PORT=8080
GATEWAY_ENV=development

# ── Internal gRPC Addresses (used by API Gateway) ───────────
AUTH_SERVICE_ADDR=auth-service:9001
WORKSPACE_SERVICE_ADDR=workspace-service:9002
PROJECT_SERVICE_ADDR=project-service:9003
INTEGRATION_SERVICE_ADDR=integration-service:9004

# ── Auth Service ─────────────────────────────────────────────
AUTH_SERVICE_PORT=9001
AUTH_SERVICE_HEALTH_PORT=8081

# ── Workspace Service ────────────────────────────────────────
WORKSPACE_SERVICE_PORT=9002
WORKSPACE_SERVICE_HEALTH_PORT=8082

# ── Project Service ──────────────────────────────────────────
PROJECT_SERVICE_PORT=9003
PROJECT_SERVICE_HEALTH_PORT=8083

# ── Integration Service ──────────────────────────────────────
INTEGRATION_SERVICE_PORT=9004
INTEGRATION_SERVICE_HEALTH_PORT=8084

# ── Secrets / Credential Encryption ──────────────────────────
# 32-byte base64 key used before storing provider credentials.
# Generate locally with: openssl rand -base64 32
CREDENTIAL_ENCRYPTION_KEY=REPLACE_WITH_BASE64_32_BYTE_KEY

# ── GitHub App (Phase 2) ─────────────────────────────────────
# Create this in GitHub Developer Settings -> GitHub Apps.
# Keep private keys and webhook secrets out of git.
GITHUB_APP_ID=REPLACE_ME
GITHUB_APP_SLUG=opspilot
GITHUB_APP_PRIVATE_KEY_PATH=./secrets/github-app.private-key.pem
GITHUB_APP_PRIVATE_KEY_BASE64=
GITHUB_APP_WEBHOOK_SECRET=REPLACE_ME
GITHUB_APP_INSTALL_URL=https://github.com/apps/REPLACE_WITH_APP_SLUG/installations/new
GITHUB_APP_CALLBACK_URL=http://localhost:8080/api/v1/integrations/github/callback
GITHUB_WEBHOOK_URL=http://localhost:8080/api/v1/webhooks/github

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_GITHUB_APP_INSTALL_URL=https://github.com/apps/REPLACE_WITH_APP_SLUG/installations/new

# ── AI (Phase 3 — fill these later) ─────────────────────────
# Groq API: https://groq.com → Console → API Keys (free)
GROQ_API_KEY=gsk_REPLACE_ME_IN_PHASE_3

# Gemini API: https://aistudio.google.com → Get API Key (free)
GEMINI_API_KEY=AIza_REPLACE_ME_IN_PHASE_3

# AI Worker
AI_WORKER_PORT=8090
AI_WORKER_HEALTH_PORT=8091
